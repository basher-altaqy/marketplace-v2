{
  "name": "marketplace-modular-v1",
  "version": "1.0.0",
  "private": true,
  "description": "Modular multi-seller marketplace with Node.js, Express, PostgreSQL and vanilla JS",
  "engines": {
    "node": ">=20.x"
  },
  "main": "server.js",
  "scripts": {
    "db:bootstrap": "node scripts/db-bootstrap.js",
    "db:reset": "node scripts/db-reset.js",
    "db:schema": "node scripts/db-bootstrap.js --schema-only",
    "seed:arabic-demo": "node scripts/seed-arabic-demo.js",
    "seed:products": "node scripts/seed-products.js",
    "start": "node server.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "web-push": "^3.6.7"
  }
}
