NODE_ENV=development
PORT=3000
JWT_SECRET=change-this-secret-in-production

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/marketplace
DB_SSL=false

# Bootstrap admin
ADMIN_PHONE=9647000000000
ADMIN_PASSWORD=change-me-please
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=Marketplace Admin
ADMIN_STORE_NAME=Marketplace Management
ADMIN_REGION=Default

# Adaptive polling (chat + notifications)
POLL_SINCE_MAX_DAYS=30
POLL_RETRY_AFTER_SECONDS=0
POLL_DEBUG_LOGS=false

# Web Push (set WEB_PUSH_ENABLED=true only after setting VAPID keys)
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_METRICS_WINDOW_HOURS=24
